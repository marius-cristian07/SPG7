<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="using:DanfossSPGroup7.UI.ViewModels"
             x:Class="DanfossSPGroup7.UI.Views.ResultView"
             x:DataType="vm:ResultViewModel"
             Background="White">

    <ScrollViewer VerticalScrollBarVisibility="Auto">

        
        <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto,Auto"
              Margin="20">

            <StackPanel Grid.Row="0" Orientation="Horizontal" Background="#F5F5F5" Spacing="20" Margin="0,0,0,20">
                <StackPanel Spacing="5">
                    <TextBlock Text="Scenarios" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Scenario 1" Command="{Binding ChangeScenarioCommand}" CommandParameter="1"/>
                        <Button Content="Scenario 2" Command="{Binding ChangeScenarioCommand}" CommandParameter="2"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Spacing="5">
                    <TextBlock Text="Season" FontWeight="Bold"/>
                    <StackPanel Orientation="Horizontal" Spacing="10">
                        <Button Content="Winter" Command="{Binding ChangeSeasonCommand}" CommandParameter="False"/>
                        <Button Content="Summer" Command="{Binding ChangeSeasonCommand}" CommandParameter="True"/>
                    </StackPanel>
                </StackPanel>
            </StackPanel>


            <TextBlock Grid.Row="1"
                       Text="Optimization Results"
                       FontSize="24"
                       FontWeight="Bold"
                       Margin="0,0,0,12"/>

            
            <TextBlock Grid.Row="2"
                       Text="Cost"
                       FontSize="24"
                       Margin="0,8,0,10"/>

            <lvc:CartesianChart Grid.Row="3"
                                Series="{Binding Series}"
                                XAxes="{Binding XAxes}"
                                YAxes="{Binding YAxes}"
                                Height="300"/>

            
            <TextBlock Grid.Row="4"
                       Text="Heat Demand"
                       FontSize="24"
                       Margin="0,20,0,10"/>

            <lvc:CartesianChart Grid.Row="5"
                                Series="{Binding HeatDemandSeries}"
                                XAxes="{Binding HeatDemandXAxes}"
                                YAxes="{Binding HeatDemandYAxes}"
                                Height="300"/>

            
            <TextBlock Grid.Row="6"
                       Text="CO2 Emissions"
                       FontSize="24"
                       Margin="0,20,0,10"/>

            <lvc:CartesianChart Grid.Row="7"
                                Series="{Binding Co2Series}"
                                XAxes="{Binding Co2XAxes}"
                                YAxes="{Binding Co2YAxes}"
                                Height="300"/>

            
           <TextBlock Grid.Row="8"
                      Text="Net Production Cost"
                      FontSize="24"
                      Margin="0,20,0,10"
                      IsVisible="{Binding IsScenario2}"/>

          <lvc:CartesianChart Grid.Row="9"
                               Series="{Binding NetProductionCostSeries}"
                               XAxes="{Binding NetCostXAxes}"
                               YAxes="{Binding NetCostYAxes}"
                               Height="300"
                               IsVisible="{Binding IsScenario2}"/>

            
            <TextBox Grid.Row="10"
                     Margin="0,12,0,0"
                     Text="{Binding ResultsText}"
                     IsReadOnly="True"
                     AcceptsReturn="True"
                     TextWrapping="Wrap"
                     MinHeight="200"/>

        </Grid>
    </ScrollViewer>
</UserControl>