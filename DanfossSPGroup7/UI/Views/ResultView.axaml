<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.Avalonia;assembly=LiveChartsCore.SkiaSharpView.Avalonia"
             xmlns:vm="using:DanfossSPGroup7.UI.ViewModels"
             x:Class="DanfossSPGroup7.UI.Views.ResultView"
             x:DataType="vm:ResultViewModel"
             Background="White">

  

    <Grid RowDefinitions="Auto,300,*" Margin="20">
        <TextBlock Text="Optimization Results"
                   FontSize="24"
                   FontWeight="Bold"
                   Margin="0,0,0,12"/>
        
        <lvc:CartesianChart Grid.Row="1"
                            Series="{Binding Series}"
                            XAxes="{Binding XAxes}"
                            YAxes="{Binding YAxes}" />
        
        <TextBox Grid.Row="2"
                 Margin="0,12,0,0"
                 Text="{Binding ResultsText}"
                 IsReadOnly="True"
                 AcceptsReturn="True"
                 TextWrapping="Wrap" />
        <TextBlock Text="Heat Demand"
           FontSize="24"
           Margin="0,20,0,10" />

        <lvc:CartesianChart Series="{Binding HeatDemandSeries}"
                    XAxes="{Binding HeatDemandXAxes}"
                    YAxes="{Binding HeatDemandYAxes}"
                    Height="300" />
    </Grid>
</UserControl>
