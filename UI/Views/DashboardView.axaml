<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DanfossSPGroup7.UI.ViewModels"
             x:Class="DanfossSPGroup7.UI.Views.DashboardView"
             x:DataType="vm:DashboardViewModel"
             Background="White">
  <Border Padding="20">
    <StackPanel Spacing="10">
      <TextBlock Text="City Map" FontSize="18" FontWeight="Bold" />
      <TextBlock Text="Heat distribution network map will be displayed here" FontSize="14" />
    </StackPanel>
  </Border>
</UserControl>
