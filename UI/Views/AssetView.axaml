<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:DanfossSPGroup7.UI.ViewModels"
             x:Class="DanfossSPGroup7.UI.Views.AssetView"
             x:DataType="vm:AssetViewModel"
             Background="White">
  <Border Padding="20">
    <StackPanel Spacing="10">
      <TextBlock Text="Scenario 1: Production Units" FontSize="18" FontWeight="Bold" />
      <TextBlock Text="3 Gas Boilers" FontSize="14" />
      <TextBlock Text="1 Oil Boiler" FontSize="14" />
    </StackPanel>
  </Border>
</UserControl>
